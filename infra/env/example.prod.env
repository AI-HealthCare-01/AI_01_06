# ==========================================
# 1. Docker Settings
# ==========================================
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# ==========================================
# 2. Database (MySQL Config)
# ==========================================
DB_HOST=mysql
DB_PORT=3306
DB_EXPOSE_PORT=3306
DB_USER=ozcoding
DB_PASSWORD=production-secure-db-password-here
DB_ROOT_PASSWORD=production-secure-root-password-here
DB_NAME=ai_health

# ==========================================
# 3. Application Security
# ==========================================
APP_VERSION=v1.0.0
AI_WORKER_VERSION=v1.0.0
SECRET_KEY=production-secure-secret-key-change-it
COOKIE_DOMAIN=api.yourdomain.com

# ==========================================
# 4. External Services (Redis)
# ==========================================
# н”„лЎңлҚ•м…ҳ нҷҳкІҪм—җм„ңлҠ” Redis мқёмҰқмқ„ нҷңм„ұнҷ”н•ҳм„ёмҡ”:
# REDIS_URL=redis://:your-redis-password@redis:6379
REDIS_URL=redis://redis:6379

# ==========================================
# 5. API Keys (LLM, OCR)
# ==========================================
OPENAI_API_KEY=production-openai-api-key-here
OPENAI_MODEL=gpt-4o
NAVER_OCR_SECRET=production-naver-ocr-secret
NAVER_OCR_URL=https://production-naver-ocr-endpoint

# ==========================================
# 6. Web Frontend
# ==========================================
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# ==========================================
# 7. Kakao OAuth (EC2 мҡҙмҳҒ вҖ” HTTPS н•„мҲҳ)
# ==========================================
# Kakao Developers Consoleм—җ https://yourdomain.com/auth/kakao/callback мқ„ Redirect URIлЎң л“ұлЎқ н•„мҲҳ
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=https://yourdomain.com/auth/kakao/callback

# ==========================================
# 8. Google OAuth (EC2 мҡҙмҳҒ вҖ” HTTPS н•„мҲҳ)
# ==========================================
# KakaoмҷҖ лӢ¬лҰ¬ GoogleмқҖ л№„-localhost URIм—җ HTTPS н•„мҲҳ
# Google Cloud Consoleм—җ https://yourdomain.com/auth/google/callback л“ұлЎқ н•„мҲҳ
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# =====================================================
# 9. Chat Bot (RAG)
# =====================================================
# RAG кё°лҠҘ нҷңм„ұнҷ” м—¬л¶Җ
# - true: мІҳл°©м „ м—°кІ° мұ„нҢ…м—җм„ң DrugDocument кё°л°ҳ retrieval нҷңм„ұнҷ”
# - false: кё°мЎҙ LLM лӢөліҖл§Ң мӮ¬мҡ©
# мӢӨм ң лЎңм»¬ мӢӨн–ү мӢңм—җлҠ” infra/env/.local.env лҳҗлҠ” лЈЁнҠё .env м—җ м„Өм •
# мҳҲ: RAG_ENABLED=true
RAG_ENABLED=false
EAYAK_API_KEY=your-eayak-api-key-here

# ==========================================
# 10. Guardian Invite Link
# ==========================================
# мҙҲлҢҖ л§ҒнҒ¬ URL prefix (API м„ңлІ„к°Җ мӮ¬мҡ©)
# EC2 мҡҙмҳҒ мӢң HTTPS н•„мҲҳ вҖ” Clipboard API, ліҙм•Ҳ м •мұ… мҡ”кө¬мӮ¬н•ӯ
# вҡ  нӣ„н–ү мҠ¬лһҳмӢң м—Ҷмқҙ м„Өм •: FRONTEND_URL=https://yourdomain.com вң…
FRONTEND_URL=https://yourdomain.com

# ==========================================
# 11. CORS Allowed Origins
# ==========================================
ALLOWED_ORIGINS=https://yourdomain.com