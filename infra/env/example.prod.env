# ==========================================
# 1. Docker Settings
# ==========================================
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# ==========================================
# 2. Database (MySQL Config)
# ==========================================
DB_HOST=mysql
DB_PORT=3306
DB_EXPOSE_PORT=3306
DB_USER=ozcoding
DB_PASSWORD=production-secure-db-password-here
DB_ROOT_PASSWORD=production-secure-root-password-here
DB_NAME=ai_health

# ==========================================
# 3. Application Security
# ==========================================
APP_VERSION=v1.0.0
AI_WORKER_VERSION=v1.0.0
SECRET_KEY=production-secure-secret-key-change-it
COOKIE_DOMAIN=api.yourdomain.com

# ==========================================
# 4. External Services (Redis)
# ==========================================
REDIS_URL=redis://redis:6379

# ==========================================
# 5. API Keys (LLM, OCR)
# ==========================================
OPENAI_API_KEY=production-openai-api-key-here
OPENAI_MODEL=gpt-4o
NAVER_OCR_SECRET=production-naver-ocr-secret
NAVER_OCR_URL=https://production-naver-ocr-endpoint

# ==========================================
# 6. Web Frontend
# ==========================================
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# ==========================================
# 7. Kakao OAuth (EC2 운영 — HTTPS 필수)
# ==========================================
# Kakao Developers Console에 https://yourdomain.com/auth/kakao/callback 을 Redirect URI로 등록 필수
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=https://yourdomain.com/auth/kakao/callback
