# ==========================================
# 1. Docker Settings
# ==========================================
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# ==========================================
# 2. Database (MySQL Config)
# ==========================================
DB_HOST=mysql
DB_PORT=3306
DB_EXPOSE_PORT=3306
MYSQL_USER=ozcoding
MYSQL_PASSWORD=your-db-password-here
MYSQL_ROOT_PASSWORD=your-root-password-here
MYSQL_DATABASE=ai_health

# 컨테이너 내부 애플리케이션(API, Worker) 주입용 완성형 URL
DATABASE_URL=mysql://ozcoding:your-db-password-here@mysql:3306/ai_health

# ==========================================
# 3. Application Security
# ==========================================
APP_VERSION=v1.0.0
AI_WORKER_VERSION=v1.0.0
SECRET_KEY=dev-secret-key-change-in-production
COOKIE_DOMAIN=localhost

# ==========================================
# 4. External Services (Redis)
# ==========================================
REDIS_URL=redis://redis:6379

# ==========================================
# 5. API Keys (LLM, OCR)
# ==========================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
NAVER_OCR_SECRET=your-naver-ocr-secret
NAVER_OCR_URL=https://your-naver-ocr-endpoint

# ==========================================
# 6. Web Frontend
# ==========================================
NEXT_PUBLIC_API_BASE_URL=

# ==========================================
# 7. Kakao OAuth (비즈앱 불필요)
# ==========================================
# Kakao Developers Console → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=your-kakao-rest-api-key
# Kakao Developers Console → 보안 → Client Secret (선택)
KAKAO_CLIENT_SECRET=your-kakao-client-secret
# Kakao Developers Console → 카카오 로그인 → Redirect URI 에 동일하게 등록 필수
# Docker Compose 기동 시 nginx(80포트)가 진입점 → localhost/auth/kakao/callback 사용
# (npm run dev 직접 실행 시에는 localhost:3000/auth/kakao/callback 사용)
KAKAO_REDIRECT_URI=http://localhost/auth/kakao/callback

# ==========================================
# 8. Google OAuth (비즈앱 불필요, 기본 OpenID Connect 스코프)
# ==========================================
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
# 승인된 리디렉션 URI에 반드시 등록 필요:
#   Docker Compose: http://localhost/auth/google/callback
#   npm run dev:    http://localhost:3000/auth/google/callback
# ⚠ 중요: Google은 localhost HTTP 허용, 그 외 도메인은 HTTPS 필수
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback

# =====================================================
# 9. Chat Bot (RAG)
# =====================================================
# RAG 기능 활성화 여부
# - true: 처방전 연결 채팅에서 DrugDocument 기반 retrieval 활성화
# - false: 기존 LLM 답변만 사용
# 실제 로컬 실행 시에는 infra/env/.local.env 또는 루트 .env 에 설정
# 예: RAG_ENABLED=true
RAG_ENABLED=false
EAYAK_API_KEY=여기에발급받은키

# ==========================================
# 10. Guardian Invite Link
# ==========================================
# 초대 링크 URL prefix (API 서버가 사용)
# Docker Compose 기동 시 nginx(80포트)가 진입점 → http://localhost 사용
# (npm run dev 직접 실행 시에는 config.py 기본값 http://localhost:3000 적용)
FRONTEND_URL=http://localhost

# ==========================================
# 11. CORS Allowed Origins
# ==========================================
ALLOWED_ORIGINS=http://localhost,http://localhost:3000