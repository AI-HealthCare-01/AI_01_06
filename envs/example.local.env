# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=oz-codingschool-AI-health260127!@
COOKIE_DOMAIN=localhost

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db
DB_HOST=localhost
DB_PORT=3306
DB_EXPOSE_PORT=3306
DB_USER=ozcoding
DB_PASSWORD=pw1234
DB_ROOT_PASSWORD=Password123@!
DB_NAME=ai_health


# =====================================================================
#                   B담당: OCR 파이프라인 환경변수
# =====================================================================


# =====================================================================
# [1] CLOVA OCR 키  <-- 여기에 넣으세요!
# =====================================================================
#
# 키 받는 방법:
#   1. https://www.ncloud.com 로그인
#   2. AI.NAVER API -> OCR -> 도메인 생성 (General OCR)
#   3. 도메인 클릭 -> "API Gateway Invoke URL" 복사 -> 아래 URL에 붙여넣기
#   4. 같은 화면 -> "Secret Key" 복사 -> 아래 SECRET_KEY에 붙여넣기

CLOVA_OCR_API_URL=여기에_API_GATEWAY_URL_붙여넣기
CLOVA_OCR_SECRET_KEY=여기에_SECRET_KEY_붙여넣기

# =====================================================================


# =====================================================================
# [2] OpenAI API 키  <-- 여기에 넣으세요!
# =====================================================================
#
# 키 받는 방법:
#   1. https://platform.openai.com 로그인
#   2. 우상단 프로필 -> API Keys -> "Create new secret key"
#   3. 생성된 sk-... 키 복사 -> 아래에 붙여넣기

OPENAI_API_KEY=sk-여기에_OPENAI_키_붙여넣기
OPENAI_MODEL=gpt-4o-mini

# =====================================================================


# =====================================================================
# [3] OCR 모드 설정  <-- 키 다 넣었으면 real 로 바꾸세요!
# =====================================================================
#
# mock -> 키 없어도 테스트 가능 (가짜 응답으로 전체 흐름 확인)
# real -> 실제 CLOVA OCR + OpenAI 호출 (위 1,2번 키 필수)

OCR_MODE=mock

# =====================================================================


# 파일 업로드 설정 (건드리지 않아도 됩니다)
UPLOAD_DIR=./uploads
STATIC_URL_PREFIX=/static
MAX_UPLOAD_SIZE_MB=10
